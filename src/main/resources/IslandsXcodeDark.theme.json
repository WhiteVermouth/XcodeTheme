      "pressedBorderColor": "activeSelection",
      "pressedBackground": "borderColor"
    },
    "Bookmark": {
      "Mnemonic": {
      }
    },
    "Borders": {
      "color": "borderColor",
      "ContrastBorderColor": "borderColor"
    },
    "Button": {
      "foreground": "#ffffff",
      "startBackground": "secondary",
      "endBackground": "secondary",
      "focusedBorderColor": "#5069c3",
      "startBorderColor": "separatorColor",
      "endBorderColor": "separatorColor",
      "disabledBorderColor": "separatorColor",
      "default": {
        "foreground": "#ffffff",
        "startBackground": "activeSelection",
        "endBackground": "activeSelection",
        "startBorderColor": "activeSelection",
        "endBorderColor": "activeSelection",
        "focusColor": "#5069c3",
        "focusedBorderColor": "#5069c3"
      }
    },
    "Counter": {
      "foreground": "#ffffff"
    },
