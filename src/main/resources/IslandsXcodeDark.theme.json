      "Header": {
        "background": "secondary",
        "inactiveBackground": "secondary"
      },
      "HeaderTab": {
        "underlineColor": "activeSelection",
        "underlineHeight": 2,
        "underlinedTabBackground": "#27282d",
        "underlinedTabInactiveBackground": "primary"
      },
      "Stripe": {
        "borderColor": "transparent"
      }
    },
    "Tree": {
      "background": "#27282d"
    },
    "VersionControl": {
      "Log": {
        "Commit": {
          "currentBranchBackground": "secondary",
          "hoveredBackground": "inactiveSelection"
        }
      }
    },
    "WelcomeScreen": {
      "SidePanel": {
        "background": "secondary"
