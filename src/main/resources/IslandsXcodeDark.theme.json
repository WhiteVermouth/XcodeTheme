    "EditorTabs": {
      "underlinedTabBackground": "#27282d",
      "background": "secondary",
      "underlineColor": "activeSelection",
      "underlineHeight": 2
    },
    "Link": {
      "activeForeground": "#0c90f8",
      "hoverForeground": "#9a61cb",
      "visitedForeground": "#0c90f8",
      "pressedForeground": "#9a61cb"
