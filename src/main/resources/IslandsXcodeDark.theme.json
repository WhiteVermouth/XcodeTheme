{
  "name": "Islands Xcode Dark",
  "dark": true,
  "author": "Zihan Ma",
  "editorScheme": "/XcodeDark.xml",
  "parentTheme": "Islands Dark",
  "colors": {
    "primary": "#212327",
    "secondary": "#343333",
    "activeSelection": "#2f55b1",
    "inactiveSelection": "#515b70",
    "borderColor": "#121212",
    "separatorColor": "#474545",
    "transparent": "#00000000"
