{
  "name": "Islands Xcode Dark",
  "dark": true,
  "author": "Zihan Ma",
  "editorScheme": "/XcodeDark.xml",
  "parentTheme": "Islands Dark",
  "colors": {
    "content": "#212327",
    "chrome": "#343333",
    "accent": "#2f55b1",
    "accentMuted": "#515b70",
    "border": "#121212",
    "separator": "#474545",
    "transparent": "#00000000"
  },
  "ui": {
    "*": {
      "arc": "8",
      "background": "content",
      "selectionBackground": "accent",
      "selectionInactiveBackground": "accentMuted",
      "disabledBackground": "content",
      "underlineColor": "accent",
      "borderColor": "border",
      "separatorColor": "separator"
    },
    "ActionButton": {
      "hoverBorderColor": "separator",
      "hoverBackground": "border",
      "pressedBorderColor": "accent",
      "pressedBackground": "border"
    },
    "Borders": {
      "color": "border",
      "ContrastBorderColor": "border"
    },
    "Button": {
      "foreground": "#ffffff",
      "startBackground": "chrome",
      "endBackground": "chrome",
      "focusedBorderColor": "#5069c3",
      "startBorderColor": "separator",
      "endBorderColor": "separator",
      "disabledBorderColor": "separator",
      "default": {
        "foreground": "#ffffff",
        "startBackground": "accent",
        "endBackground": "accent",
        "startBorderColor": "accent",
        "endBorderColor": "accent",
        "focusColor": "#5069c3",
        "focusedBorderColor": "#5069c3"
      }
    },
    "Counter": {
      "foreground": "#ffffff"
    },
    "ComboBox": {
      "nonEditableBackground": "chrome",
      "ArrowButton": {
        "background": "chrome",
        "nonEditableBackground": "chrome"
      }
    },
    "CompletionPopup": {
      "matchForeground": "#fc5fa3"
    },
    "Component": {
      "focusColor": "accent",
      "borderColor": "accentMuted",
      "focusedBorderColor": "accent",
      "disabledBorderColor": "accentMuted"
    },
    "Editor": {
      "shortcutForeground": "accent",
      "background": "content"
    },
    "EditorTabs": {
      "underlinedTabBackground": "#27282d",
      "background": "content",
      "underlineColor": "accent",
      "underlineHeight": 2
    },
    "Link": {
      "activeForeground": "#0c90f8",
      "hoverForeground": "#9a61cb",
      "visitedForeground": "#0c90f8",
      "pressedForeground": "#9a61cb"
    },
    "Notification": {
      "borderColor": "accentMuted",
      "ToolWindow": {
        "informativeBackground": "content",
        "informativeBorderColor": "#42b827",
        "informativeForeground": "#ffffff",
        "warningBackground": "content",
        "errorBackground": "content"
      }
    },
    "NotificationsToolwindow": {
      "newNotification": {
        "background": "chrome",
        "hoverBackground": "chrome"
      },
      "Notification": {
        "hoverBackground": "chrome"
      }
    },
    "Plugins": {
      "hoverBackground": "#3c414c",
      "lightSelectionBackground": "#3c414c"
    },
    "PasswordField": {
      "background": "chrome"
    },
    "SearchMatch": {
      "startBackground": "#eeed38",
      "endBackground": "#eeed38"
    },
    "SearchEverywhere": {
      "SearchField": {
        "background": "chrome"
      },
      "Tab": {
        "selectedBackground": "accentMuted"
      }
    },
    "Separator": {
      "separatorColor": "separator"
    },
    "SidePanel": {
      "background": "content"
    },
    "StatusBar": {
      "background": "chrome",
      "borderColor": "transparent"
    },
    "Table": {
      "hoverBackground": "accentMuted",
      "lightSelectionBackground": "#3c414c"
    },
    "TableHeader": {
      "bottomSeparatorColor": "separator"
    },
    "TextField": {
      "background": "chrome"
    },
    "ToggleButton": {
      "onBackground": "#338f1b"
    },
    "Island": {
      "borderColor": "border",
      "arc": "20"
    },
    "ToolWindow": {
      "background": "content",
      "Button": {
        "selectedBackground": "#131313",
        "hoverBackground": "border"
      },
      "Header": {
        "background": "content",
        "inactiveBackground": "content"
      },
      "HeaderTab": {
        "underlineColor": "accent",
        "underlineHeight": 2,
        "underlinedTabBackground": "#27282d",
        "underlinedTabInactiveBackground": "content"
      },
      "Stripe": {
        "background": "chrome",
        "borderColor": "transparent"
      }
    },
    "Tree": {
      "rowHeight": 20,
      "background": "content"
    },
    "VersionControl": {
      "Log": {
        "Commit": {
          "currentBranchBackground": "chrome",
          "hoveredBackground": "accentMuted"
        }
      }
    },
    "WelcomeScreen": {
      "SidePanel": {
        "background": "chrome"
      },
      "separatorColor": "separator",
      "Projects": {
        "background": "accentMuted",
        "selectionBackground": "chrome",
        "selectionInactiveBackground": "chrome",
        "actions": {
          "background": "chrome"
        }
      },
      "Details": {
        "background": "content"
      }
    },
    "MainToolbar": {
      "background": "chrome",
      "borderColor": "transparent"
    },
    "MainWindow": {
      "background": "chrome"
    }
  },
  "icons": {
    "ColorPalette": {
      "Actions.Red": "#c63a5d",
      "Actions.Yellow": "#caba2d",
      "Actions.Green": "#25ad6b",
      "Actions.Blue": "#4d85ff",
      "Objects.RedStatus": "#dd3962",
      "Objects.Red": "#c63a5d",
      "Objects.Pink": "#f98b9e",
      "Objects.Yellow": "#caba2d",
      "Objects.Green": "#239e62",
      "Objects.Blue": "#598bff",
      "Objects.Purple": "#af71e0",
      "Objects.BlackText": "#000000ff",
      "Objects.YellowDark": "#988c26",
      "Objects.GreenAndroid": "#78c257",
      "Checkbox.Border.Default": "#121212",
      "Checkbox.Border.Default.Dark": "#121212",
      "Checkbox.Background.Default": "#343333",
      "Checkbox.Background.Default.Dark": "#343333",
      "Checkbox.Background.Disabled": "#212327",
      "Checkbox.Background.Disabled.Dark": "#212327",
      "Checkbox.Focus.Wide": "#2f55b1",
      "Checkbox.Focus.Wide.Dark": "#2f55b1"
    }
  }
}
